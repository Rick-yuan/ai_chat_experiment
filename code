                contentDiv.id = 'typing-message';
                
                messageDiv.appendChild(avatarDiv);
                messageDiv.appendChild(contentDiv);
                chatMessages.appendChild(messageDiv);
            }

            const typingMessage = document.getElementById('typing-message');
            
            if (index < message.length) {
                typingMessage.textContent = message.substring(0, index + 1);
                chatMessages.scrollTop = chatMessages.scrollHeight;
                setTimeout(() => typeMessage(message, index + 1), 50);
            } else {
                typingMessage.removeAttribute('id');
                isTyping = false;
                sendBtn.disabled = false;
                userInput.disabled = false;
                userInput.focus();
            }
        }

        function sendMessage() {
            const message = userInput.value.trim();
            
            if (message === '' || isTyping) return;
            
            addMessage(message, true);
            userInput.value = '';
            
            isTyping = true;
            sendBtn.disabled = true;
            userInput.disabled = true;
            
            // 显示思考过程
            showThinking();
            
            setTimeout(() => {
                // 移除思考过程
                removeThinking();
                const response = aiResponses[currentResponseIndex];
                typeMessage(response);
                currentResponseIndex = (currentResponseIndex + 1) % aiResponses.length;
            }, 1000);
        }

        sendBtn.addEventListener('click', sendMessage);

        userInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                sendMessage();
            }
        });

        window.addEventListener('load', () => {
            setTimeout(() => {
                showThinking();
                setTimeout(() => {
                    removeThinking();
                    const response = aiResponses[currentResponseIndex];
                    typeMessage(response);
                    currentResponseIndex = (currentResponseIndex + 1) % aiResponses.length;
                }, 2500);
            }, 800);
        });

        const studentInfoContainer = document.getElementById('studentInfoContainer');
        const studentInfoForm = document.getElementById('studentInfoForm');
        const studentErrorMessage = document.getElementById('studentErrorMessage');
        const startTestBtn = document.getElementById('startTestBtn');
        const chatContainer = document.getElementById('chatContainer');
        const surveyContainer = document.getElementById('surveyContainer');
        const backBtn = document.getElementById('backBtn');
        const surveyForm = document.getElementById('surveyForm');
        const errorMessage = document.getElementById('errorMessage');
        const successMessage = document.getElementById('successMessage');

        let studentInfo = {};

        studentInfoForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            const formData = new FormData(studentInfoForm);
            const studentId = formData.get('studentId').trim();
            const gender = formData.get('gender');
            const age = formData.get('age');
            const className = formData.get('className').trim();

            if (!studentId || !gender || !age || !className) {
                studentErrorMessage.style.display = 'block';
                return;
            }

            studentInfo = {
                studentId: studentId,
                gender: gender,
                age: parseInt(age),
                className: className
            };

            studentErrorMessage.style.display = 'none';
            
            // 显示选择讲解方式的弹窗
            const instructionModal = document.getElementById('instructionModal');
            instructionModal.style.display = 'flex';
            
            // 处理弹窗选项选择
            const modalOptions = document.querySelectorAll('.modal-option');
            let selectedInstruction = null;
            
            modalOptions.forEach(option => {
                option.addEventListener('click', () => {
                    modalOptions.forEach(opt => opt.classList.remove('selected'));
                    option.classList.add('selected');
                    selectedInstruction = option.getAttribute('data-value');
                });
            });
            
            // 处理确认按钮
            document.getElementById('modalConfirm').addEventListener('click', () => {
                if (selectedInstruction) {
                    studentInfo.instructionType = selectedInstruction;
                    instructionModal.style.display = 'none';
                    studentInfoContainer.style.display = 'none';
                    
                    if (selectedInstruction === 'AI讲解') {
                        chatContainer.style.display = 'flex';
                        startTestBtn.style.display = 'block';
                        teacherContainer.style.display = 'none';
                        document.getElementById('teacherStartTestBtn').style.display = 'none';
                    } else if (selectedInstruction === '教师讲解') {
                        teacherContainer.style.display = 'flex';
                        chatContainer.style.display = 'none';
                        startTestBtn.style.display = 'none';
                        document.getElementById('teacherStartTestBtn').style.display = 'block';
                    }
                }
            });
            
            // 处理取消按钮
            document.getElementById('modalCancel').addEventListener('click', () => {
                instructionModal.style.display = 'none';
            });
        });

        startTestBtn.addEventListener('click', () => {
            chatContainer.style.display = 'none';
            surveyContainer.style.display = 'block';
            startTestBtn.style.display = 'none';
        });

        const teacherContainer = document.getElementById('teacherContainer');
        const aiAcknowledgeBtn = document.getElementById('aiAcknowledgeBtn');
        const teacherAcknowledgeBtn = document.getElementById('teacherAcknowledgeBtn');

        backBtn.addEventListener('click', () => {
            surveyContainer.style.display = 'none';
            chatContainer.style.display = 'flex';
            startTestBtn.style.display = 'block';
            errorMessage.style.display = 'none';
            successMessage.style.display = 'none';
        });

        // 处理AI讲解页面的"我已知晓"按钮
        aiAcknowledgeBtn.addEventListener('click', () => {
            chatContainer.style.display = 'none';
            teacherContainer.style.display = 'flex';
            startTestBtn.style.display = 'none';
            document.getElementById('teacherStartTestBtn').style.display = 'block';
            // 移除教师讲解页面的"我已知晓"按钮
            teacherAcknowledgeBtn.style.display = 'none';
        });

        // 处理教师讲解页面的"我已知晓"按钮
        teacherAcknowledgeBtn.addEventListener('click', () => {
            teacherContainer.style.display = 'none';
            chatContainer.style.display = 'flex';
            startTestBtn.style.display = 'block';
            document.getElementById('teacherStartTestBtn').style.display = 'none';
            // 移除AI讲解页面的"我已知晓"按钮
            aiAcknowledgeBtn.style.display = 'none';
        });

        // 处理教师讲解页面的开始测试按钮
        document.getElementById('teacherStartTestBtn').addEventListener('click', () => {
            teacherContainer.style.display = 'none';
            surveyContainer.style.display = 'block';
            document.getElementById('teacherStartTestBtn').style.display = 'none';
        });

        surveyForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            const formData = new FormData(surveyForm);
            const answers = {};
            let allAnswered = true;

            // 检查新增的两道题
            const q0_1 = formData.get('q0_1');
            const q0_2 = formData.get('q0_2');
            if (!q0_1 || !q0_2) {
                allAnswered = false;
            }
            answers['耳鸣消除方法'] = parseInt(q0_1);
            answers['AI使用频率'] = parseInt(q0_2);

            // 检查原有的6道题
            for (let i = 1; i <= 6; i++) {
                const value = formData.get(`q${i}`);
                if (!value) {
                    allAnswered = false;
                    break;
                }
                answers[`问题${i}`] = parseInt(value);
            }

            // 检查性格特点的8道题
            for (let i = 1; i <= 8; i++) {
                const value = formData.get(`p${i}`);
                if (!value) {
                    allAnswered = false;
                    break;
                }
                answers[`性格题目${i}`] = parseInt(value);
            }

            if (!allAnswered) {
                errorMessage.style.display = 'block';
                successMessage.style.display = 'none';
                return;
            }

            errorMessage.style.display = 'none';
            
            const timestamp = new Date().toISOString();
            const surveyData = {
                timestamp: timestamp,
                studentInfo: studentInfo,
                answers: answers
            };

            const jsonData = JSON.stringify(surveyData, null, 2);
            const blob = new Blob([jsonData], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${studentInfo.studentId}.json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);

            const csvData = '学号,性别,年龄,班级,讲解方式,耳鸣消除方法,AI使用频率,时间戳,问题1,问题2,问题3,问题4,问题5,问题6,性格题目1,性格题目2,性格题目3,性格题目4,性格题目5,性格题目6,性格题目7,性格题目8\n' + 
                studentInfo.studentId + ',' +
                studentInfo.gender + ',' +
                studentInfo.age + ',' +
                studentInfo.className + ',' +
                (studentInfo.instructionType || '') + ',' +
                answers['耳鸣消除方法'] + ',' +
                answers['AI使用频率'] + ',' +
                timestamp + ',' +
                answers['问题1'] + ',' +
                answers['问题2'] + ',' +
                answers['问题3'] + ',' +
                answers['问题4'] + ',' +
                answers['问题5'] + ',' +
                answers['问题6'] + ',' +
                answers['性格题目1'] + ',' +
                answers['性格题目2'] + ',' +
                answers['性格题目3'] + ',' +
                answers['性格题目4'] + ',' +
                answers['性格题目5'] + ',' +
                answers['性格题目6'] + ',' +
                answers['性格题目7'] + ',' +
                answers['性格题目8'] + '\n';
            
            const csvBlob = new Blob(['\ufeff' + csvData], { type: 'text/csv;charset=utf-8;' });
            const csvUrl = URL.createObjectURL(csvBlob);
            const csvA = document.createElement('a');
            csvA.href = csvUrl;
            csvA.download = `${studentInfo.studentId}.csv`;
            document.body.appendChild(csvA);
            csvA.click();
            document.body.removeChild(csvA);
            URL.revokeObjectURL(csvUrl);

            successMessage.style.display = 'block';
            surveyForm.reset();
        });
    </script>
</body>
</html>
